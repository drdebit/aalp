{;; Use deps.edn for dependencies
 :deps true

 ;; Fixed nREPL port for consistent Emacs/CIDER connections
 :nrepl {:port 7888}

 :dev-http {8081 {:root "resources/public"
                  :proxy-url "http://localhost:3000"}}

 :builds
 {:app {:target :browser
        :output-dir "resources/public/js"
        :asset-path "/js"
        :modules {:main {:init-fn assertive-app.core/init}}
        :devtools {}}}}}
